{
  "name": "landingpage",
  "version": "0.6.0",
  "private": true,
  "engines": {
    "node": "^20.20.0 || >=22.22.0"
  },
  "scripts": {
    "dev": "next dev",
    "next:build": "next build",
    "cf:build": "opennextjs-cloudflare build --skipNextBuild",
    "build": "npm run next:build && npm run cf:build",
    "start": "next start",
    "lint": "eslint",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare deploy",
    "deploy": "npm run build && npm run cf:deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@opennextjs/cloudflare": "^1.19.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "figma-developer-mcp": "^0.11.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
