{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stitch": {
      "type": "local",
      "command": [
        "npx",
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "enabled": true,
      "environment": {
        "STITCH_API_KEY": "{env:STITCH_API_KEY}"
      }
    },
   "figma-desktop": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "enabled": true
    }
  }
}